# Application
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
LOG_LEVEL=INFO

# Redis
REDIS_URL=redis://redis:6379
TASK_STATUS_EXPIRY_SECONDS=1800

# Google GenAI / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-google-cloud-project
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/workdir/gcp-credentials.json
GEMINI_MODEL_NAME=gemini-2.5-pro
GEMINI_GENERATION_PROFILE=default
GEMINI_TEMPERATURE=0
GEMINI_TOP_P=1
GEMINI_TOP_K=100

# Legacy Gemini API key mode, used only when GOOGLE_GENAI_USE_VERTEXAI=false
GEMINI_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Auth
JWT_SECRET_KEY=replace-with-a-long-random-secret
REFRESH_SECRET_KEY=replace-with-a-different-long-random-secret
ACCESS_TOKEN_EXPIRE_SECONDS=86400
REFRESH_TOKEN_EXPIRE_SECONDS=604800
ADMIN_USER_IDS=

# AWS S3 / SES
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name
SENDER_EMAIL_ADDRESS="Aiditor <noreply@example.com>"
S3_PRESIGNED_URL_EXPIRY_SECONDS=3600

# Paddle billing
PADDLE_API_BASE_URL=https://sandbox-api.paddle.com
PADDLE_API_KEY=your-paddle-api-key
PADDLE_CLIENT_TOKEN=your-paddle-client-token
PADDLE_WEBHOOK_SECRET=your-paddle-webhook-secret
PADDLE_PRO_PLAN_PRICE_ID=pri_your_pro_plan_price_id
PADDLE_CREDITS_20_PRICE_ID=pri_your_credits_20_price_id
PADDLE_CREDITS_100_PRICE_ID=pri_your_credits_100_price_id
PADDLE_CREDITS_500_PRICE_ID=pri_your_credits_500_price_id
